{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.correctover/correctover-mcp-server",
  "description": "MCP Reliability Layer — 6-dimension AI output validation with self-healing failover",
  "repository": {
    "url": "https://github.com/Correctover/mcp-server",
    "source": "github"
  },
  "version": "1.0.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "correctover-mcp-server",
      "version": "1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "OPENAI_API_KEY",
          "description": "OpenAI API key",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "ANTHROPIC_API_KEY",
          "description": "Anthropic API key",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "DEEPSEEK_API_KEY",
          "description": "DeepSeek API key",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
